# Скопируйте в .env или используйте готовый .env в папке project.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Модель с Vision для распознавания товара по фото (по умолчанию gpt-4o-mini)
OPENAI_VISION_MODEL=gpt-4o-mini
FLASK_SECRET_KEY=change-me-for-production
# Продакшен: включить secure-cookie для сессии (только HTTPS)
# FLASK_ENV=production
# или: CRAFT_HUB_PRODUCTION=1
